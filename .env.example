# Only required if you register agents backed by a real LLM (e.g.
# LLMQualityChecker instead of the default heuristic checker).
# The demo workers and heuristic quality checker need no API key at all.
ANTHROPIC_API_KEY=your-api-key-here

AUDIT_DB_PATH=agent_ops.db
STATE_DB_PATH=agent_ops_state.db

# escalation-agent integration (see README "Connecting the real escalation-agent
# service"). escalation-agent must be running separately; this repo calls it
# over HTTP, it does not need escalation-agent's own dependencies or code.
ESCALATION_AGENT_URL=http://localhost:8001
# Only required if escalation-agent has ESCALATION_AGENT_API_KEY set -- must match.
ESCALATION_AGENT_API_KEY=

# Platform API auth (see src/api/auth.py). If both are unset, the API runs
# unauthenticated in dev mode.
AGENT_OPS_ADMIN_KEY=
AGENT_OPS_REVIEWER_KEY=
ALLOWED_ORIGINS=
